<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.ai\.gami\.jp$ [NC]
  RewriteRule ^ https://ai.gami.jp%{REQUEST_URI} [R=301,L,NE]

  RewriteRule ^(.*/)?index\.html$ https://ai.gami.jp/$1 [R=301,L,NE]
  RewriteRule ^\.ftp-deploy-sync-state\.json$ - [F,L]

  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]
  RewriteRule ^ index.php [L,QSA]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/plain "access plus 5 minutes"
  ExpiresByType application/xml "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|png|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:html|php|xml|txt)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
</IfModule>

# Contact form environment variables (can be overridden by Xserver panel if needed)
SetEnv GAMI_CONTACT_TO info@ai.gami.jp
SetEnv GAMI_MAIL_FROM noreply@ai.gami.jp
